# Copy this file to .env and fill in your real key.
# Never commit .env. It is ignored by Git.

# Preferred generic key name used by API App:
APIAPP_API_KEY=nvapi-your-key-here

# NVIDIA defaults:
APIAPP_BASE_URL=https://integrate.api.nvidia.com/v1
APIAPP_MODEL=deepseek-ai/deepseek-v4-pro
APIAPP_TEMPERATURE=1
APIAPP_TOP_P=0.95
APIAPP_MAX_TOKENS=16384
APIAPP_THINKING=false

# Optional local server settings:
APIAPP_HOST=127.0.0.1
APIAPP_PORT=8765
